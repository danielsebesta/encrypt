---
import Layout from '../../layouts/Layout.astro';
import EncryptTunnelView from '../../components/tools/EncryptTunnel.svelte';
import { getTranslations, t, type Locale } from '../../lib/i18n';
import DownloadStandalone from '../../components/DownloadStandalone.astro';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const dict = getTranslations(locale);
---

<Layout
  title={t(dict, 'tools.ghostDropPage.meta.title')}
  description={t(dict, 'tools.ghostDropPage.meta.description')}
>
  <div class="max-w-4xl mx-auto px-5 py-12 md:py-20 text-center">
    <div class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        {t(dict, 'tools.ghostDropPage.h1')} <span class="text-emerald-500">{t(dict, 'tools.ghostDropPage.h1Highlight')}</span>
      </h1>
      <p class="text-zinc-500 dark:text-zinc-400 text-sm md:text-base leading-relaxed max-w-2xl mx-auto">
        {t(dict, 'tools.ghostDropPage.subtitle')}
      </p>
    </div>
    <div class="card p-8">
      <EncryptTunnelView client:load locale={locale} />
    </div>

    <div class="mt-12 text-left space-y-6 max-w-2xl mx-auto">
      <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-400">{t(dict, 'tools.ghostDropPage.howItWorks')}</h3>

      <div class="grid gap-4 text-xs text-zinc-500 leading-relaxed">
        <div class="p-4 bg-zinc-50 dark:bg-zinc-900/50 rounded-xl border border-zinc-100 dark:border-zinc-800">
          <div class="font-bold text-zinc-700 dark:text-zinc-300 mb-1">{t(dict, 'tools.ghostDropPage.step1Title')}</div>
          <p>{t(dict, 'tools.ghostDropPage.step1Text')}</p>
        </div>

        <div class="p-4 bg-zinc-50 dark:bg-zinc-900/50 rounded-xl border border-zinc-100 dark:border-zinc-800">
          <div class="font-bold text-zinc-700 dark:text-zinc-300 mb-1">{t(dict, 'tools.ghostDropPage.step2Title')}</div>
          <p>{t(dict, 'tools.ghostDropPage.step2Text')}</p>
        </div>

        <div class="p-4 bg-zinc-50 dark:bg-zinc-900/50 rounded-xl border border-zinc-100 dark:border-zinc-800">
          <div class="font-bold text-zinc-700 dark:text-zinc-300 mb-1">{t(dict, 'tools.ghostDropPage.step3Title')}</div>
          <p>{t(dict, 'tools.ghostDropPage.step3Text')}</p>
        </div>
      </div>

      <div class="p-4 bg-amber-50 dark:bg-amber-950/20 rounded-xl border border-amber-200 dark:border-amber-900/50">
        <div class="text-[11px] text-amber-700 dark:text-amber-400">
          <strong>{t(dict, 'tools.ghostDropPage.importantLabel')}</strong> {t(dict, 'tools.ghostDropPage.importantText')}
        </div>
      </div>
    </div>
    <DownloadStandalone slug="ghost-drop" locale={locale} />
  </div>
</Layout>
