---
import Layout from '../../layouts/Layout.astro';
import EncryptTunnelView from '../../components/tools/EncryptTunnel.svelte';
import { getTranslations, t, type Locale } from '../../lib/i18n';
import DownloadStandalone from '../../components/DownloadStandalone.astro';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const dict = getTranslations(locale);
---

<Layout
  title="Ghost Drop — Encrypted File Sharing"
  description="Encrypt files with AES-256-GCM and upload to anonymous hosting. Smart provider selection with steganography support for maximum privacy."
>
  <div class="max-w-4xl mx-auto px-5 py-12 md:py-20 text-center">
    <div class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Ghost <span class="text-emerald-500">Drop.</span>
      </h1>
      <p class="text-zinc-500 dark:text-zinc-400 text-sm md:text-base leading-relaxed max-w-2xl mx-auto">
        Encrypt your files with AES-256-GCM and upload to anonymous hosting.
        Choose how long your file stays online — the best provider is picked automatically.
      </p>
    </div>
    <div class="card p-8">
      <EncryptTunnelView client:load />
    </div>

    <div class="mt-12 text-left space-y-6 max-w-2xl mx-auto">
      <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-400">How Ghost Drop works</h3>

      <div class="grid gap-4 text-xs text-zinc-500 leading-relaxed">
        <div class="p-4 bg-zinc-50 dark:bg-zinc-900/50 rounded-xl border border-zinc-100 dark:border-zinc-800">
          <div class="font-bold text-zinc-700 dark:text-zinc-300 mb-1">1. Client-side Encryption</div>
          <p>Your file is encrypted in your browser using AES-256-GCM with a password-derived key (PBKDF2, 100k iterations). The server never sees your plaintext or password.</p>
        </div>

        <div class="p-4 bg-zinc-50 dark:bg-zinc-900/50 rounded-xl border border-zinc-100 dark:border-zinc-800">
          <div class="font-bold text-zinc-700 dark:text-zinc-300 mb-1">2. Smart Upload</div>
          <p>Set your desired retention and the best hosting provider is selected automatically. Small files can use steganography to hide data inside PNG images. Your IP is hidden behind our proxy.</p>
        </div>

        <div class="p-4 bg-zinc-50 dark:bg-zinc-900/50 rounded-xl border border-zinc-100 dark:border-zinc-800">
          <div class="font-bold text-zinc-700 dark:text-zinc-300 mb-1">3. Share Securely</div>
          <p>Share the file URL and password through separate channels. The recipient uses the Decrypt tab to download and decrypt the file in their browser.</p>
        </div>
      </div>

      <div class="p-4 bg-amber-50 dark:bg-amber-950/20 rounded-xl border border-amber-200 dark:border-amber-900/50">
        <div class="text-[11px] text-amber-700 dark:text-amber-400">
          <strong>Important:</strong> Save your encryption password! Without it, the file cannot be decrypted. Share the password through a separate secure channel.
        </div>
      </div>
    </div>
    <DownloadStandalone slug="ghost-drop" locale={locale} />
  </div>
</Layout>
