---
import Layout from '../../layouts/Layout.astro';
import TimeCapsuleView from '../../components/tools/TimeCapsule.svelte';
import { getTranslations, t, type Locale } from '../../lib/i18n';
import { getToolEducation } from '../../lib/toolEducation';
import ToolQuickFacts from '../../components/tool-education/ToolQuickFacts.astro';
import ToolEducationPanel from '../../components/tool-education/ToolEducationPanel.astro';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const dict = getTranslations(locale);
const education = getToolEducation(locale, 'time-capsule');
import DownloadStandalone from '../../components/DownloadStandalone.astro';
---

<Layout 
  title={education.metaTitle}
  description={education.metaDescription}
>
  <div class="max-w-6xl mx-auto px-5 py-12 md:py-20 space-y-8">
    <div class="tool-hero" data-aos data-aos-delay="0">
      <div class="tool-hero__copy">
        <div class="tool-hero__chips">
          <span class="tool-chip">{t(dict, 'toolEducation.metaCategory')}: {education.hero.category}</span>
          <span class="tool-chip">{t(dict, 'toolEducation.metaDifficulty')}: {education.hero.difficulty}</span>
          {education.hero.bestFor.map((tag) => (
            <span class="tool-chip tool-chip-soft">{tag}</span>
          ))}
        </div>
        <h1 class="tool-hero__title">{t(dict, 'tools.timeCapsule.h1')} <span class="text-emerald-500">{t(dict, 'tools.timeCapsule.h1Highlight')}</span></h1>
        <p class="tool-hero__subtitle max-w-3xl">{t(dict, 'tools.timeCapsule.subtitle')}</p>
      </div>
    </div>
    <div class="card p-6 md:p-8" data-aos data-aos-delay="80">
      <TimeCapsuleView client:load locale={locale} />
    </div>

    <div data-aos data-aos-delay="120">
      <ToolQuickFacts dict={dict} quick={education.quick} />
    </div>

    <p class="text-[11px] text-zinc-400 max-w-xl" data-aos data-aos-delay="140">{t(dict, 'tools.timeCapsule.footnote')}</p>

    <div data-aos data-aos-delay="160">
      <ToolEducationPanel dict={dict} entry={education} />
    </div>
    <DownloadStandalone slug="time-capsule" locale={locale} />
  </div>
</Layout>
