---
import Layout from '../../layouts/Layout.astro';
import TokenGenView from '../../components/tools/TokenGen.svelte';
import { getTranslations, t, type Locale } from '../../lib/i18n';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const dict = getTranslations(locale);
---

<Layout 
  title={t(dict, 'tools.token.meta.title')}
  description={t(dict, 'tools.token.meta.description')}
>
  <div class="max-w-4xl mx-auto px-5 py-12 md:py-20">
    <div class="tool-hero">
      <div class="tool-hero__copy">
        <h1 class="tool-hero__title">{t(dict, 'tools.token.h1')} <span class="text-emerald-500">{t(dict, 'tools.token.h1Highlight')}</span></h1>
        <p class="tool-hero__subtitle">{t(dict, 'tools.token.subtitle')}</p>
      </div>
    </div>
    <div class="mt-8">
      <TokenGenView client:load locale={locale} />
    </div>
    <div class="mt-10 pt-8 border-t border-zinc-200/60 dark:border-zinc-800/40 text-left space-y-2">
      <h3 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300">{t(dict, 'tools.token.info.title')}</h3>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">{t(dict, 'tools.token.info.text')}</p>
    </div>
  </div>
</Layout>
