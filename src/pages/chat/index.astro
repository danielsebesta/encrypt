---
import Layout from '../../layouts/Layout.astro';
import ChatCreate from '../../components/tools/ChatCreate.svelte';
import { getTranslations, t, type Locale } from '../../lib/i18n';

const locale = (Astro.currentLocale ?? 'en') as Locale;
const dict = getTranslations(locale);

export const prerender = true;
---

<Layout
  title={t(dict, 'chat.meta.createTitle')}
  description={t(dict, 'chat.meta.createDescription')}
>
  <div class="max-w-lg mx-auto px-5 py-12 md:py-20 text-center">
    <div class="mb-8 space-y-3">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight">
        {t(dict, 'chat.pageTitle')} <span class="text-emerald-500">{t(dict, 'chat.pageTitleHighlight')}</span>
      </h1>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed max-w-sm mx-auto">
        {t(dict, 'chat.pageSubtitle')}
      </p>
    </div>
    <ChatCreate client:load locale={locale} />
  </div>
</Layout>
