---
import { t } from '../../lib/i18n';

type Props = {
  dict: Record<string, string>;
};

const { dict } = Astro.props;
---

<section class="home-shell">
  <div class="max-w-7xl mx-auto px-5 pt-6 pb-20 md:pt-10 md:pb-28">
    <div class="home-cta-card" data-aos data-aos-delay="0">
      <div class="max-w-2xl">
        <span class="home-kicker">{t(dict, 'home.cta.eyebrow')}</span>
        <h2 class="mt-3 text-3xl md:text-5xl font-black tracking-[-0.04em] text-zinc-950 dark:text-zinc-50">
          {t(dict, 'home.cta.title')}
          <span class="text-emerald-600 dark:text-emerald-400"> {t(dict, 'home.cta.titleHighlight')}</span>
        </h2>
        <p class="mt-4 text-sm md:text-base leading-7 text-zinc-600 dark:text-zinc-300">
          {t(dict, 'home.cta.subtitle')}
        </p>
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/tools/aes-words" class="btn px-6 py-3.5 text-sm md:text-base">{t(dict, 'home.cta.primary')}</a>
        <a href="/tools/token" class="btn-outline px-6 py-3.5 text-sm md:text-base">{t(dict, 'home.cta.secondary')}</a>
      </div>
    </div>
  </div>
</section>
