---
import { t } from '../../lib/i18n';

type Props = {
  dict: Record<string, string>;
};

const { dict } = Astro.props;
---

<section class="relative z-1">
  <div class="max-w-7xl mx-auto px-5 pb-20 md:pb-28">
    <div class="bento-card p-8 md:p-12">
      <div class="grid md:grid-cols-[1fr_auto] gap-8 items-center">
        <div data-aos data-aos-delay="0">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-600 dark:text-emerald-400 mb-3">
            {t(dict, 'home.privacyExplainer.eyebrow')}
          </p>
          <h2 class="text-2xl md:text-4xl font-black tracking-[-0.03em] text-zinc-950 dark:text-zinc-50 max-w-xl">
            {t(dict, 'home.privacyExplainer.title')}
          </h2>
          <p class="mt-4 text-sm md:text-base leading-7 text-zinc-500 dark:text-zinc-400 max-w-lg">
            {t(dict, 'home.privacyExplainer.p1')}
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/tools/aes-words" class="btn px-6 py-3 text-sm">{t(dict, 'home.cta.primary')}</a>
            <a
              href="https://github.com/danielsebesta/encrypt.click"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-outline px-6 py-3 text-sm"
            >
              {t(dict, 'home.privacyExplainer.cta')}
            </a>
          </div>
        </div>

        <div class="hidden md:block" data-aos data-aos-delay="120">
          <img
            src="/encrypt_lock.svg"
            alt=""
            class="w-32 lg:w-44 h-auto opacity-80 dark:opacity-60"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>
