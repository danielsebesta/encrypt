---
import { t } from '../../lib/i18n';

type Props = {
  dict: Record<string, string>;
};

const { dict } = Astro.props;

const categories = [
  {
    icon: '01',
    tag: t(dict, 'home.discovery.private.tag'),
    title: t(dict, 'home.discovery.private.title'),
    text: t(dict, 'home.discovery.private.text'),
    tools: [
      { label: t(dict, 'home.discovery.private.tool1'), href: '/tools/aes-words' },
      { label: t(dict, 'home.discovery.private.tool2'), href: '/tools/photo-cipher' },
      { label: t(dict, 'home.discovery.private.tool3'), href: '/drop' },
    ],
    cta: t(dict, 'home.discovery.private.cta'),
    href: '/tools/aes-words',
  },
  {
    icon: '10',
    tag: t(dict, 'home.discovery.dev.tag'),
    title: t(dict, 'home.discovery.dev.title'),
    text: t(dict, 'home.discovery.dev.text'),
    tools: [
      { label: t(dict, 'home.discovery.dev.tool1'), href: '/tools/token' },
      { label: t(dict, 'home.discovery.dev.tool2'), href: '/tools/jwt' },
      { label: t(dict, 'home.discovery.dev.tool3'), href: '/tools/rsa' },
    ],
    cta: t(dict, 'home.discovery.dev.cta'),
    href: '/tools/token',
  },
  {
    icon: '11',
    tag: t(dict, 'home.discovery.learn.tag'),
    title: t(dict, 'home.discovery.learn.title'),
    text: t(dict, 'home.discovery.learn.text'),
    tools: [
      { label: t(dict, 'home.discovery.learn.tool1'), href: '/tools/enigma' },
      { label: t(dict, 'home.discovery.learn.tool2'), href: '/tools/caesar' },
      { label: t(dict, 'home.discovery.learn.tool3'), href: '/tools/vigenere' },
    ],
    cta: t(dict, 'home.discovery.learn.cta'),
    href: '/tools/enigma',
  },
];
---

<section class="home-shell">
  <div class="max-w-7xl mx-auto px-5 py-16 md:py-24">
    <div class="max-w-2xl mb-8 md:mb-12" data-aos data-aos-delay="0">
      <span class="home-kicker">{t(dict, 'home.discovery.eyebrow')}</span>
      <h2 class="mt-3 text-3xl md:text-5xl font-black tracking-[-0.04em] text-zinc-950 dark:text-zinc-50">
        {t(dict, 'home.discovery.title')}
      </h2>
      <p class="mt-4 text-sm md:text-base leading-7 text-zinc-600 dark:text-zinc-300">
        {t(dict, 'home.discovery.subtitle')}
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-5 md:gap-6">
      {categories.map((category, index) => (
        <article class="home-discovery-card" data-aos data-aos-delay={index === 0 ? 0 : index === 1 ? 60 : 120}>
          <div class="flex items-start justify-between gap-4">
            <div>
              <span class="home-discovery-card__tag">{category.tag}</span>
              <h3 class="mt-4 text-2xl font-black tracking-[-0.03em] text-zinc-950 dark:text-zinc-50">
                {category.title}
              </h3>
            </div>
            <span class="home-discovery-card__icon" aria-hidden="true">{category.icon}</span>
          </div>

          <p class="mt-4 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
            {category.text}
          </p>

          <ul class="mt-5 space-y-2">
            {category.tools.map((tool) => (
              <li>
                <a href={tool.href} class="home-inline-link">{tool.label}</a>
              </li>
            ))}
          </ul>

          <div class="mt-6 pt-5 border-t border-zinc-200/80 dark:border-zinc-800/80">
            <a href={category.href} class="btn-secondary px-5 py-3 text-sm">{category.cta}</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
