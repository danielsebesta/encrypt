---
import { t } from '../../lib/i18n';

type Props = {
  dict: Record<string, string>;
};

const { dict } = Astro.props;

const categories = [
  {
    title: t(dict, 'home.discovery.private.title'),
    text: t(dict, 'home.discovery.private.text'),
    tools: [
      { label: t(dict, 'home.discovery.private.tool1'), href: '/tools/aes-words' },
      { label: t(dict, 'home.discovery.private.tool2'), href: '/tools/photo-cipher' },
      { label: t(dict, 'home.discovery.private.tool3'), href: '/drop' },
    ],
  },
  {
    title: t(dict, 'home.discovery.dev.title'),
    text: t(dict, 'home.discovery.dev.text'),
    tools: [
      { label: t(dict, 'home.discovery.dev.tool1'), href: '/tools/token' },
      { label: t(dict, 'home.discovery.dev.tool2'), href: '/tools/jwt' },
      { label: t(dict, 'home.discovery.dev.tool3'), href: '/tools/rsa' },
    ],
  },
  {
    title: t(dict, 'home.discovery.learn.title'),
    text: t(dict, 'home.discovery.learn.text'),
    tools: [
      { label: t(dict, 'home.discovery.learn.tool1'), href: '/tools/enigma' },
      { label: t(dict, 'home.discovery.learn.tool2'), href: '/tools/caesar' },
      { label: t(dict, 'home.discovery.learn.tool3'), href: '/tools/vigenere' },
    ],
  },
];
---

<section class="relative z-1">
  <div class="max-w-7xl mx-auto px-5 py-16 md:py-24">
    <div class="max-w-xl mb-10 md:mb-14" data-aos data-aos-delay="0">
      <h2 class="text-2xl md:text-4xl font-black tracking-[-0.03em] text-zinc-950 dark:text-zinc-50">
        {t(dict, 'home.discovery.title')}
      </h2>
      <p class="mt-3 text-sm md:text-base leading-7 text-zinc-500 dark:text-zinc-400">
        {t(dict, 'home.discovery.subtitle')}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-px bg-zinc-200/70 dark:bg-zinc-800/50 rounded-2xl overflow-hidden border border-zinc-200/70 dark:border-zinc-800/50">
      {categories.map((cat, i) => (
        <article
          class="bg-white dark:bg-zinc-950/60 p-6 md:p-8 flex flex-col"
          data-aos
          data-aos-delay={i * 60}
        >
          <h3 class="text-lg font-black tracking-tight text-zinc-900 dark:text-zinc-100">
            {cat.title}
          </h3>
          <p class="mt-2 text-sm leading-6 text-zinc-500 dark:text-zinc-400 flex-1">
            {cat.text}
          </p>
          <ul class="mt-5 space-y-1.5">
            {cat.tools.map((tool) => (
              <li>
                <a href={tool.href} class="home-tool-link">
                  <span class="home-tool-link__dot" aria-hidden="true"></span>
                  {tool.label}
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
