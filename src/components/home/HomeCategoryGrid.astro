---
import { t } from '../../lib/i18n';

type Props = {
  dict: Record<string, string>;
};

const { dict } = Astro.props;

const privateTools = [
  { label: t(dict, 'home.discovery.private.tool1'), href: '/tools/aes-words' },
  { label: t(dict, 'home.discovery.private.tool2'), href: '/tools/photo-cipher' },
  { label: t(dict, 'home.discovery.private.tool3'), href: '/drop' },
];

const devTools = [
  { label: t(dict, 'home.discovery.dev.tool1'), href: '/tools/token' },
  { label: t(dict, 'home.discovery.dev.tool2'), href: '/tools/jwt' },
  { label: t(dict, 'home.discovery.dev.tool3'), href: '/tools/rsa' },
];

const learnTools = [
  { label: t(dict, 'home.discovery.learn.tool1'), href: '/tools/enigma' },
  { label: t(dict, 'home.discovery.learn.tool2'), href: '/tools/caesar' },
  { label: t(dict, 'home.discovery.learn.tool3'), href: '/tools/vigenere' },
];
---

<section class="relative z-1">
  <div class="max-w-6xl mx-auto px-5 py-16 md:py-24">
    <div class="max-w-xl mb-10 md:mb-14" data-aos data-aos-delay="0">
      <h2 class="text-2xl md:text-4xl font-black tracking-[-0.03em] text-zinc-950 dark:text-zinc-50">
        {t(dict, 'home.discovery.title')}
      </h2>
      <p class="mt-3 text-sm md:text-base leading-7 text-zinc-500 dark:text-zinc-400">
        {t(dict, 'home.discovery.subtitle')}
      </p>
    </div>

    <div class="grid grid-cols-6 gap-3">
      <!-- Hero card: 100% client-side -->
      <div class="bento-card col-span-full lg:col-span-2 flex items-center justify-center" data-aos data-aos-delay="0">
        <div class="py-8 text-center">
          <div class="relative inline-flex items-center justify-center h-20 w-48">
            <svg class="absolute inset-0 w-full h-full text-emerald-200 dark:text-emerald-900/40" viewBox="0 0 254 104" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M112.891 97.7022C140.366 97.0802 171.004 94.6715 201.087 87.5116C210.43 85.2881 219.615 82.6412 228.284 78.2473C232.198 76.3179 235.905 73.9942 239.348 71.3124C241.85 69.2557 243.954 66.7571 245.555 63.9408C249.34 57.3235 248.281 50.5341 242.498 45.6109C239.033 42.7237 235.228 40.2703 231.169 38.3054C219.443 32.7209 207.141 28.4382 194.482 25.534C184.013 23.1927 173.358 21.7755 162.64 21.2989C161.376 21.3512 160.113 21.181 158.908 20.796C158.034 20.399 156.857 19.1682 156.962 18.4535C157.115 17.8927 157.381 17.3689 157.743 16.9139C158.104 16.4588 158.555 16.0821 159.067 15.8066C160.14 15.4683 161.274 15.3733 162.389 15.5286C179.805 15.3566 196.626 18.8373 212.998 24.462C220.978 27.2494 228.798 30.4747 236.423 34.1232C240.476 36.1159 244.202 38.7131 247.474 41.8258C254.342 48.2578 255.745 56.9397 251.841 65.4892C249.793 69.8582 246.736 73.6777 242.921 76.6327C236.224 82.0192 228.522 85.4602 220.502 88.2924C205.017 93.7847 188.964 96.9081 172.738 99.2109C153.442 101.949 133.993 103.478 114.506 103.79C91.1468 104.161 67.9334 102.97 45.1169 97.5831C36.0094 95.5616 27.2626 92.1655 19.1771 87.5116C13.839 84.5746 9.1557 80.5802 5.41318 75.7725C-0.54238 67.7259 -1.13794 59.1763 3.25594 50.2827C5.82447 45.3918 9.29572 41.0315 13.4863 37.4319C24.2989 27.5721 37.0438 20.9681 50.5431 15.7272C68.1451 8.8849 86.4883 5.1395 105.175 2.83669C129.045 0.0992292 153.151 0.134761 177.013 2.94256C197.672 5.23215 218.04 9.01724 237.588 16.3889C240.089 17.3418 242.498 18.5197 244.933 19.6446C246.627 20.4387 247.725 21.6695 246.997 23.615C246.455 25.1105 244.814 25.5605 242.63 24.5811C230.322 18.9961 217.233 16.1904 204.117 13.4376C188.761 10.3438 173.2 8.36665 157.558 7.52174C129.914 5.70776 102.154 8.06792 75.2124 14.5228C60.6177 17.8788 46.5758 23.2977 33.5102 30.6161C26.6595 34.3329 20.4123 39.0673 14.9818 44.658C12.9433 46.8071 11.1336 49.1622 9.58207 51.6855C4.87056 59.5336 5.61172 67.2494 11.9246 73.7608C15.2064 77.0494 18.8775 79.925 22.8564 82.3236C31.6176 87.7101 41.3848 90.5291 51.3902 92.5804C70.6068 96.5773 90.0219 97.7419 112.891 97.7022Z" fill="currentColor" />
            </svg>
            <span class="relative text-4xl md:text-5xl font-black text-zinc-900 dark:text-zinc-50">100%</span>
          </div>
          <h3 class="mt-4 text-xl font-black tracking-tight text-zinc-900 dark:text-zinc-100">Client-side</h3>
          <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">{t(dict, 'home.hero.proof1')}</p>
        </div>
      </div>

      <!-- Private sharing -->
      <div class="bento-card col-span-full sm:col-span-3 lg:col-span-2" data-aos data-aos-delay="60">
        <div class="p-6 md:p-8">
          <div class="flex items-center justify-center h-28 mb-4">
            <div class="relative flex aspect-square size-24 rounded-full border border-emerald-200 dark:border-emerald-900/60 before:absolute before:-inset-2.5 before:rounded-full before:border before:border-emerald-100 dark:before:border-emerald-900/30">
              <svg class="m-auto" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-600 dark:text-emerald-400"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
          </div>
          <h3 class="text-lg font-bold text-zinc-900 dark:text-zinc-100">{t(dict, 'home.discovery.private.title')}</h3>
          <p class="mt-2 text-sm leading-6 text-zinc-500 dark:text-zinc-400">{t(dict, 'home.discovery.private.text')}</p>
          <ul class="mt-5 space-y-1.5">
            {privateTools.map((tool) => (
              <li><a href={tool.href} class="home-tool-link"><span class="home-tool-link__dot" aria-hidden="true"></span>{tool.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Developer tools -->
      <div class="bento-card col-span-full sm:col-span-3 lg:col-span-2" data-aos data-aos-delay="120">
        <div class="p-6 md:p-8">
          <div class="flex items-center justify-center h-28 mb-4">
            <div class="relative flex aspect-square size-24 rounded-full border border-zinc-200 dark:border-zinc-800 before:absolute before:-inset-2.5 before:rounded-full before:border before:border-zinc-100 dark:before:border-zinc-800/60">
              <svg class="m-auto" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-600 dark:text-zinc-400"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </div>
          </div>
          <h3 class="text-lg font-bold text-zinc-900 dark:text-zinc-100">{t(dict, 'home.discovery.dev.title')}</h3>
          <p class="mt-2 text-sm leading-6 text-zinc-500 dark:text-zinc-400">{t(dict, 'home.discovery.dev.text')}</p>
          <ul class="mt-5 space-y-1.5">
            {devTools.map((tool) => (
              <li><a href={tool.href} class="home-tool-link"><span class="home-tool-link__dot" aria-hidden="true"></span>{tool.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Learning tools — wide card -->
      <div class="bento-card col-span-full lg:col-span-3" data-aos data-aos-delay="0">
        <div class="p-6 md:p-8 grid sm:grid-cols-2 gap-6 items-center">
          <div>
            <h3 class="text-lg font-bold text-zinc-900 dark:text-zinc-100">{t(dict, 'home.discovery.learn.title')}</h3>
            <p class="mt-2 text-sm leading-6 text-zinc-500 dark:text-zinc-400">{t(dict, 'home.discovery.learn.text')}</p>
            <ul class="mt-5 space-y-1.5">
              {learnTools.map((tool) => (
                <li><a href={tool.href} class="home-tool-link"><span class="home-tool-link__dot" aria-hidden="true"></span>{tool.label}</a></li>
              ))}
            </ul>
          </div>
          <div class="hidden sm:flex items-center justify-center">
            <img src="/encrypt_lock.svg" alt="" class="w-28 lg:w-36 h-auto opacity-70 dark:opacity-50" loading="lazy" />
          </div>
        </div>
      </div>

      <!-- Open source — wide card -->
      <div class="bento-card col-span-full lg:col-span-3" data-aos data-aos-delay="60">
        <div class="p-6 md:p-8 grid sm:grid-cols-2 gap-6 items-center">
          <div>
            <h3 class="text-lg font-bold text-zinc-900 dark:text-zinc-100">{t(dict, 'home.privacyExplainer.title')}</h3>
            <p class="mt-2 text-sm leading-6 text-zinc-500 dark:text-zinc-400">{t(dict, 'home.privacyExplainer.p1')}</p>
            <div class="mt-5">
              <a
                href="https://github.com/danielsebesta/encrypt.click"
                target="_blank"
                rel="noopener noreferrer"
                class="home-tool-link"
              >
                <span class="home-tool-link__dot" aria-hidden="true"></span>
                {t(dict, 'home.privacyExplainer.cta')}
              </a>
            </div>
          </div>
          <div class="hidden sm:block">
            <div class="rounded-xl border border-zinc-200/80 dark:border-zinc-800/60 bg-zinc-50/50 dark:bg-zinc-900/30 p-4">
              <div class="flex items-center gap-1.5 mb-3">
                <span class="block size-2 rounded-full bg-zinc-300 dark:bg-zinc-700"></span>
                <span class="block size-2 rounded-full bg-zinc-300 dark:bg-zinc-700"></span>
                <span class="block size-2 rounded-full bg-zinc-300 dark:bg-zinc-700"></span>
              </div>
              <div class="space-y-2">
                <div class="h-2 w-3/4 rounded bg-emerald-200/60 dark:bg-emerald-900/30"></div>
                <div class="h-2 w-full rounded bg-zinc-200/80 dark:bg-zinc-800/60"></div>
                <div class="h-2 w-full rounded bg-zinc-200/80 dark:bg-zinc-800/60"></div>
                <div class="h-2 w-1/2 rounded bg-zinc-200/80 dark:bg-zinc-800/60"></div>
                <div class="h-2 w-5/6 rounded bg-emerald-200/60 dark:bg-emerald-900/30 mt-3"></div>
                <div class="h-2 w-full rounded bg-zinc-200/80 dark:bg-zinc-800/60"></div>
                <div class="h-2 w-2/3 rounded bg-zinc-200/80 dark:bg-zinc-800/60"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
