---
import SecurityShield from '../SecurityShield.svelte';
import { t } from '../../lib/i18n';

type Props = {
  dict: Record<string, string>;
};

const { dict } = Astro.props;
const claims = [
  { title: t(dict, 'home.proof.claim1.title'), text: t(dict, 'home.proof.claim1.text') },
  { title: t(dict, 'home.proof.claim2.title'), text: t(dict, 'home.proof.claim2.text') },
  { title: t(dict, 'home.proof.claim3.title'), text: t(dict, 'home.proof.claim3.text') },
  { title: t(dict, 'home.proof.claim4.title'), text: t(dict, 'home.proof.claim4.text') },
];
---

<section class="home-shell">
  <div class="max-w-7xl mx-auto px-5 py-6 md:py-8">
    <div data-aos data-aos-delay="0">
      <div class="max-w-2xl">
        <h2 class="text-2xl md:text-3xl font-black tracking-[-0.03em] text-zinc-950 dark:text-zinc-50">
          {t(dict, 'home.proof.title')}
        </h2>
        <p class="mt-3 text-sm md:text-base leading-7 text-zinc-600 dark:text-zinc-300">
          {t(dict, 'home.proof.subtitle')}
        </p>
      </div>

      <div class="home-proof-list mt-6 md:mt-8">
        <div class="grid sm:grid-cols-2 gap-x-6 gap-y-4 flex-1">
          {claims.map((claim, index) => (
            <div data-aos data-aos-delay={index % 2 === 0 ? 60 : 120}>
              <p class="home-proof-list__title">{claim.title}</p>
              <p class="home-proof-list__text">{claim.text}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-6 md:mt-8 pt-5 md:pt-6 border-t border-zinc-200/80 dark:border-zinc-800/90">
        <SecurityShield client:load compact={true} />
      </div>
    </div>
  </div>
</section>
