---
import UltimateEncrypt from '../tools/UltimateEncrypt.svelte';
import ChatCreate from '../tools/ChatCreate.svelte';
import { t, type Locale } from '../../lib/i18n';

type Props = {
  locale: Locale;
  dict: Record<string, string>;
};

const { locale, dict } = Astro.props;
---

<section class="home-hero-section">
  <div class="max-w-5xl mx-auto px-5 relative z-1">

    <!-- Hero header with lock icon -->
    <div class="text-center mb-12 md:mb-16" data-aos data-aos-delay="0">
      <img
        src="/encrypt_lock.svg"
        alt=""
        class="mx-auto w-20 md:w-28 h-auto mb-6"
      />
      <h1 class="text-3xl md:text-5xl lg:text-6xl leading-[1.08] tracking-[-0.04em] font-black text-zinc-950 dark:text-zinc-50">
        {t(dict, 'home.hero.title.line1')}
        <span class="text-emerald-600 dark:text-emerald-400"> {t(dict, 'home.hero.title.line2')}</span>
      </h1>
      <p class="mt-4 max-w-xl mx-auto text-base md:text-lg leading-7 text-zinc-500 dark:text-zinc-400">
        {t(dict, 'home.hero.subtitle')}
      </p>
      <p class="mt-3 text-sm text-zinc-400 dark:text-zinc-500">
        {t(dict, 'home.hero.note')}
      </p>
    </div>

    <!-- Two tool panels side by side -->
    <div class="grid md:grid-cols-2 gap-5" data-aos data-aos-delay="60">

      <!-- Encrypt widget -->
      <div class="home-tool-panel">
        <div class="flex items-center gap-2 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-500"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <p class="text-base font-bold text-zinc-800 dark:text-zinc-200">{t(dict, 'home.hero.panelTitle')}</p>
        </div>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-4 leading-relaxed">
          {t(dict, 'home.hero.proof1')}
        </p>
        <div class="home-tool-panel__surface">
          <UltimateEncrypt client:load locale={locale} />
        </div>
      </div>

      <!-- Chat widget -->
      <div class="home-tool-panel">
        <div class="flex items-center gap-2 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-500"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
          <p class="text-base font-bold text-zinc-800 dark:text-zinc-200">{t(dict, 'chat.pageTitle')} <span class="text-emerald-500">{t(dict, 'chat.pageTitleHighlight')}</span></p>
        </div>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-4 leading-relaxed">
          {t(dict, 'chat.pageSubtitle')}
        </p>
        <ChatCreate client:load locale={locale} />
      </div>

    </div>

  </div>
</section>
