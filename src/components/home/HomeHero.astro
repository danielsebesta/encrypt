---
import UltimateEncrypt from '../tools/UltimateEncrypt.svelte';
import { t, type Locale } from '../../lib/i18n';

type Props = {
  locale: Locale;
  dict: Record<string, string>;
};

const { locale, dict } = Astro.props;
---

<section class="home-hero-section">
  <div class="max-w-6xl mx-auto px-5 pt-10 md:pt-16 pb-10 md:pb-14 relative z-1">
    <div class="grid lg:grid-cols-[minmax(0,1fr)_minmax(22rem,28rem)] gap-8 lg:gap-10 items-start">
      <!-- Left: hero text -->
      <div class="space-y-5 pt-2 md:pt-6" data-aos data-aos-delay="0">
        <h1 class="text-3xl md:text-5xl lg:text-6xl leading-[1.05] tracking-[-0.04em] font-black text-zinc-950 dark:text-zinc-50">
          {t(dict, 'home.hero.title.line1')}
          <br />
          <span class="text-emerald-600 dark:text-emerald-400">{t(dict, 'home.hero.title.line2')}</span>
        </h1>
        <p class="max-w-md text-sm md:text-base leading-7 text-zinc-500 dark:text-zinc-400">
          {t(dict, 'home.hero.subtitle')}
        </p>
        <p class="text-xs text-zinc-400 dark:text-zinc-500 max-w-sm">
          {t(dict, 'home.hero.note')}
        </p>
      </div>

      <!-- Right: encrypt widget -->
      <div id="encrypt-tool" data-aos data-aos-delay="60">
        <div class="home-tool-panel">
          <p class="home-tool-panel__title">{t(dict, 'home.hero.panelTitle')}</p>
          <div class="home-tool-panel__surface">
            <UltimateEncrypt client:load locale={locale} />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
