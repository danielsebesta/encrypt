---
---

<canvas id="pixel-grid" class="pixel-grid" aria-hidden="true"></canvas>

<script>
  const canvas = document.getElementById('pixel-grid') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const CELL = 28;
    const DOT = 2;
    let cols = 0;
    let rows = 0;
    let glows: { col: number; row: number; life: number; maxLife: number; delay: number }[] = [];
    let frame = 0;

    function resize() {
      const dpr = Math.min(window.devicePixelRatio, 2);
      const rect = canvas.parentElement!.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      canvas.style.width = rect.width + 'px';
      canvas.style.height = rect.height + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      cols = Math.ceil(rect.width / CELL) + 1;
      rows = Math.ceil(rect.height / CELL) + 1;
    }

    function spawnGlow() {
      if (glows.length > 12) return;
      const maxLife = 60 + Math.random() * 120;
      glows.push({
        col: Math.floor(Math.random() * cols),
        row: Math.floor(Math.random() * rows),
        life: 0,
        maxLife,
        delay: Math.random() * 30,
      });
    }

    function draw() {
      const w = canvas.width / Math.min(window.devicePixelRatio, 2);
      const h = canvas.height / Math.min(window.devicePixelRatio, 2);
      ctx.clearRect(0, 0, w, h);

      const isDark = document.documentElement.classList.contains('dark');
      const baseAlpha = isDark ? 0.08 : 0.06;

      // base grid dots
      for (let c = 0; c < cols; c++) {
        for (let r = 0; r < rows; r++) {
          const x = c * CELL;
          const y = r * CELL;
          ctx.fillStyle = isDark
            ? `rgba(161, 161, 170, ${baseAlpha})`
            : `rgba(63, 63, 70, ${baseAlpha})`;
          ctx.beginPath();
          ctx.arc(x, y, DOT, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      // animated glows
      for (let i = glows.length - 1; i >= 0; i--) {
        const g = glows[i];
        if (g.delay > 0) { g.delay--; continue; }
        g.life++;
        if (g.life > g.maxLife) { glows.splice(i, 1); continue; }

        const t = g.life / g.maxLife;
        const intensity = t < 0.3 ? t / 0.3 : 1 - (t - 0.3) / 0.7;
        const x = g.col * CELL;
        const y = g.row * CELL;

        // outer glow
        const grad = ctx.createRadialGradient(x, y, 0, x, y, CELL * 2.5);
        grad.addColorStop(0, `rgba(16, 185, 129, ${0.12 * intensity})`);
        grad.addColorStop(1, 'rgba(16, 185, 129, 0)');
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.arc(x, y, CELL * 2.5, 0, Math.PI * 2);
        ctx.fill();

        // bright dot
        ctx.fillStyle = `rgba(16, 185, 129, ${0.7 * intensity})`;
        ctx.beginPath();
        ctx.arc(x, y, DOT + 1, 0, Math.PI * 2);
        ctx.fill();
      }

      frame++;
      if (frame % 20 === 0) spawnGlow();
      requestAnimationFrame(draw);
    }

    resize();
    // seed initial glows
    for (let i = 0; i < 6; i++) spawnGlow();
    draw();
    window.addEventListener('resize', resize);
  }
</script>

<style>
  .pixel-grid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    mask-image: linear-gradient(to bottom, rgba(0,0,0,0.6), rgba(0,0,0,0.2) 60%, transparent 95%);
  }
</style>
