---
/**
 * Download button for the standalone offline HTML version of a tool.
 * Usage: <DownloadStandalone slug="caesar" locale={locale} />
 * 
 * Uses fetch + blob to force a real file download (browsers ignore the
 * `download` attribute on same-origin .html files and render them instead).
 */
import { getTranslations, t, type Locale } from '../lib/i18n';

interface Props {
  slug: string;
  locale?: Locale;
}

const { slug, locale = 'en' } = Astro.props;
const dict = getTranslations(locale);
---

<div class="mt-8 flex justify-center">
  <button
    type="button"
    data-dl-url={`/standalone/${slug}.html`}
    data-dl-name={`${slug}.html`}
    class="standalone-dl-btn inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-900/50 hover:border-emerald-500 hover:bg-emerald-50 dark:hover:bg-emerald-950/20 transition-all text-xs font-semibold text-zinc-600 dark:text-zinc-400 hover:text-emerald-700 dark:hover:text-emerald-400 group cursor-pointer"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-60 group-hover:opacity-100 transition-opacity"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
    {t(dict, 'standalone.download')}
    <span class="text-[10px] font-normal opacity-60">— {t(dict, 'standalone.description')}</span>
  </button>
</div>

<script is:inline>
(function() {
  if (window.__standaloneDownloadBound) return;
  window.__standaloneDownloadBound = true;
  document.addEventListener('click', function(e) {
    var btn = e.target.closest && e.target.closest('[data-dl-url]');
    if (!btn) return;
    e.preventDefault();
    var url = btn.getAttribute('data-dl-url');
    var name = btn.getAttribute('data-dl-name');
    var xhr = new XMLHttpRequest();
    xhr.open('GET', url, true);
    xhr.responseType = 'blob';
    xhr.onload = function() {
      if (xhr.status === 200) {
        var blob = xhr.response;
        // Use msSaveBlob for IE/Edge legacy
        if (window.navigator.msSaveBlob) {
          window.navigator.msSaveBlob(blob, name);
          return;
        }
        var blobUrl = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.style.display = 'none';
        a.href = blobUrl;
        a.download = name;
        document.body.appendChild(a);
        a.click();
        // Give the browser enough time to start the download
        setTimeout(function() {
          URL.revokeObjectURL(blobUrl);
          document.body.removeChild(a);
        }, 5000);
      }
    };
    xhr.onerror = function() {
      // Fallback: direct link navigation
      var a = document.createElement('a');
      a.href = url;
      a.download = name;
      document.body.appendChild(a);
      a.click();
      a.remove();
    };
    xhr.send();
  });
})();
</script>
