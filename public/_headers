/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 0
  Referrer-Policy: no-referrer
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Cross-Origin-Opener-Policy: same-origin
  Access-Control-Allow-Origin: https://encrypt.click
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self' https://*.encrypt.click https://*.partykit.dev wss://*.partykit.dev; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'; upgrade-insecure-requests
  Server: encrypt.click

/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/theme-init.js
  Cache-Control: public, max-age=31536000, immutable

/encryptclick_icon.svg
  Cache-Control: public, max-age=31536000, immutable

/encrypt_*.svg
  Cache-Control: public, max-age=31536000, immutable
